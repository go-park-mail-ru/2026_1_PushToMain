                "body": {
                    "type": "string"
                },
                "created_at": {
                    "type": "string"
                },
                "header": {
                    "type": "string"
                },
                "id": {
                    "type": "integer"
                },
                "is_read": {
                    "type": "boolean"
                },
                "sender_id": {
                    "type": "integer"
                }
