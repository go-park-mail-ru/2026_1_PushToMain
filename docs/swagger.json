{
    "swagger": "2.0",
    "info": {
        "title": "Smail API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8087",
    "basePath": "/",
    "paths": {
        "/emails": {
            "get": {
                "description": "Возвращает список писем, в которых пользователь указан получателем",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "emails"
                ],
                "summary": "Получить письма пользователя",
                "parameters": [
                    {
                        "description": "Владелец почты",
                        "name": "input",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/handler.EmailRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/models.Email"
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "handler.EmailRequest": {
            "type": "object",
            "properties": {
                "owner": {
                    "type": "string"
                }
            }
        },
        "models.Email": {
            "type": "object",
            "properties": {
                "body": {
                    "type": "string"
                },
                "email-id": {
                    "type": "string"
                },
                "from": {
                    "type": "string"
                },
                "header": {
                    "type": "string"
                },
                "to": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        }
    }
}